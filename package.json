{
  "name": "qa-automation-portfolio",
  "version": "1.0.0",
  "description": "QA Automation Portfolio — Playwright, Selenium, BDD, Karate, REST Assured",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:mobile": "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:api": "npx playwright test tests/api",
    "test:visual": "npx playwright test tests/visual",
    "test:update-snapshots": "npx playwright test --update-snapshots",
    "report": "npx playwright show-report",
    "codegen": "npx playwright codegen",
    "lint": "npx tsc --noEmit",
    "test:jmeter": "mvn verify -f performance/jmeter/pom.xml",
    "test:k6:smoke": "docker run --rm -v $(pwd)/performance/k6:/scripts grafana/k6 run /scripts/smoke-test.js",
    "test:k6:load": "docker run --rm -v $(pwd)/performance/k6:/scripts grafana/k6 run /scripts/load-test.js",
    "test:k6:stress": "docker run --rm -v $(pwd)/performance/k6:/scripts grafana/k6 run /scripts/stress-test.js",
    "test:k6:all": "npm run test:k6:smoke && npm run test:k6:load && npm run test:k6:stress",
    "test:selenium": "cd selenium-webdriver && mvn clean test",
    "test:flutter": "export PATH=\"$PATH:/opt/flutter/bin\" && cd flutter_app && flutter test",
    "test:appium": "cd appium && mvn clean test -DappPath=../app/build/wikipedia.apk",
    "test:cypress:open": "npx cypress open",
    "test:cypress:run": "npx cypress run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Signaltree/qa-automation-portfolio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Signaltree/qa-automation-portfolio/issues"
  },
  "homepage": "https://github.com/Signaltree/qa-automation-portfolio#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "cypress": "^14.2.1"
  }
}
